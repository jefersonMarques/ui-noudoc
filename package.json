{
  "name": "@noudoc/ui",
  "version": "0.1.0",
  "description": "Noudoc UI kit based on official shadcn-svelte components.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "ui:init": "shadcn-svelte init --base-color zinc --css src/routes/layout.css --lib-alias $lib --components-alias $lib/components --utils-alias $lib/utils --hooks-alias $lib/hooks --ui-alias $lib/components/ui --overwrite",
    "ui:add:base": "shadcn-svelte add button field input textarea select checkbox switch badge card dialog dropdown-menu popover tooltip table tabs empty sidebar --overwrite"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "components.json",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles.css": {
      "default": "./dist/styles.css"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.21.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "publint": "^0.3.21",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "shadcn-svelte",
    "tailwindcss",
    "design-system",
    "saas"
  ]
}
